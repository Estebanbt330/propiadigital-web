# Supabase — stores contact form leads.
# The site works without these (leads are logged to the server console),
# but set them in production to persist leads.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional public anon key (if you prefer it over the service role key)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Resend — sends the lead notification email.
# Get the API key at https://resend.com (starts with "re_").
RESEND_API_KEY=
